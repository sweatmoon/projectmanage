# ============================================================
# .env.live.example  ─  라이브 서버 환경변수 템플릿
# ============================================================
# 1) cp .env.live.example .env.live
# 2) .env.live 파일을 편집해서 실제 값 입력
# 3) .env.live 는 절대 Git에 커밋하지 마세요! (.gitignore 에 등록됨)
#
# 실행:
#   docker compose --env-file .env.live \
#     -f docker-compose.yml \
#     -f docker-compose.live.yml \
#     up -d
# ============================================================

# ── [공통] 서버 기본 설정 ────────────────────────────────────
PORT=8080
ENVIRONMENT=production

# ── [라이브] 컨테이너 호스트 포트 ────────────────────────────
# 스테이징은 8888, 라이브는 8890 (겹치지 않게 설정)
# NAS 역방향 프록시 또는 라우터 포트포워딩과 맞출 것
APP_HOST_PORT=8890

# ── [공통] PostgreSQL DB 설정 ────────────────────────────────
# 스테이징과 다른 비밀번호 사용 권장
# 생성법: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change_me_live_password

# ── [공통] JWT 설정 ──────────────────────────────────────────
# 스테이징과 반드시 다른 값 사용 (토큰 교차 사용 방지)
# 생성법: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-live-jwt-secret-at-least-32-chars
JWT_EXPIRE_HOURS=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ── [인증] Google OAuth 설정 (권장) ─────────────────────────
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Google Cloud Console 설정 방법:
#   1. https://console.cloud.google.com/apis/credentials
#   2. 기존 OAuth 2.0 클라이언트 ID 선택 (또는 새로 생성)
#   3. "승인된 리디렉션 URI" 에 라이브 URL 추가:
#      https://[라이브도메인]/auth/callback
#   4. 아래 값 입력
#
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── [라이브] 앱 URL 및 OAuth 콜백 ───────────────────────────
# 라이브 서버의 실제 접속 주소로 변경
# 예시:
#   NAS 역방향 프록시:  https://activo-no1.synology.me:8453
#   커스텀 도메인:      https://app.mycompany.com
#   Railway:           https://myapp-live.up.railway.app
APP_URL=https://activo-no1.synology.me:8453
OIDC_REDIRECT_URI=https://activo-no1.synology.me:8453/auth/callback

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ── [인증] Synology SSO 설정 (Google OAuth 대신 사용 시) ────
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Google OAuth가 설정되면 이 항목은 무시됨
# OIDC_ISSUER_URL=https://activo-no1.synology.me/webman/sso
# OIDC_CLIENT_ID=your_oidc_client_id
# OIDC_CLIENT_SECRET=your_oidc_client_secret

# ── [공통] 관리자 계정 ───────────────────────────────────────
# Google 계정 이메일(Google OAuth) 또는 Synology ID(SSO)
# 쉼표로 구분하여 여러 명 입력 가능
ADMIN_USERS=your_email@gmail.com

# ── [라이브] Docker 이미지 태그 ──────────────────────────────
# live 브랜치 → sweatmoon/gantt-app:live
IMAGE_TAG=live

# ── [운영] 백업 보관 기간 ────────────────────────────────────
BACKUP_KEEP_DAYS=30

# ── [운영 선택] Watchtower 이메일 알림 ──────────────────────
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=

# ── [개발] 로그 수준 ─────────────────────────────────────────
LOG_LEVEL=INFO

# ====================================================
# 프로젝트 일정 관리 시스템 - 환경 변수 설정
# ====================================================
# 이 파일을 복사하여 .env 로 만든 후 실제 값을 입력하세요.
# cp .env.example .env

# ── 서버 기본 설정 ──────────────────────────────────
PORT=8080
ENVIRONMENT=production

# ── PostgreSQL DB 설정 ───────────────────────────────
# docker-compose.yml 에서 자동으로 postgresql://gantt@db/ganttdb 로 연결됨
# 아래 비밀번호는 실제 사용할 값으로 변경하세요!
POSTGRES_PASSWORD=ganttpass_change_me

# DATABASE_URL은 docker-compose 에서 자동 설정되므로 보통 수정 불필요
# DATABASE_URL=postgresql+asyncpg://gantt:ganttpass@db:5432/ganttdb

# ── JWT 설정 ─────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열로 변경 (필수!)
# 생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=8

# ── 시놀로지 NAS OIDC 설정 ──────────────────────────
OIDC_ISSUER_URL=https://YOUR_NAS_DOMAIN/webman/sso
OIDC_CLIENT_ID=your_application_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI=https://YOUR_APP_DOMAIN:8443/auth/callback
APP_URL=https://YOUR_APP_DOMAIN:8443

# ── 백업 설정 ────────────────────────────────────────
# DB 백업 보관 기간 (일)
BACKUP_KEEP_DAYS=30

# ── 선택적 설정 ──────────────────────────────────────
LOG_LEVEL=INFO

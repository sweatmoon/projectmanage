# ============================================================
# .env.example  ─  환경 변수 템플릿
# ============================================================
# 1) cp .env.example .env
# 2) .env 파일을 편집해서 실제 값 입력
# 3) .env 는 절대 Git에 커밋하지 마세요! (.gitignore 에 등록됨)
# ============================================================

# ── [공통] 서버 기본 설정 ────────────────────────────────────
PORT=8080

# development | production
ENVIRONMENT=production

# ── [공통] PostgreSQL DB 설정 ────────────────────────────────
# docker-compose 가 자동으로 DATABASE_URL 을 조립합니다.
# 아래 비밀번호를 안전한 값으로 변경하세요 (필수!)
# 생성법: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change_me_please

# ── [공통] JWT 설정 ──────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열 (필수!)
# 생성법: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=8

# ── [운영] 시놀로지 NAS OIDC 설정 ───────────────────────────
# 개발 환경에서는 비워두면 dev-login(자동 관리자) 활성화
# 운영 환경에서는 아래 4개 값을 반드시 입력
OIDC_ISSUER_URL=https://YOUR_NAS_DOMAIN/webman/sso
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_REDIRECT_URI=https://YOUR_APP_DOMAIN:8443/auth/callback
APP_URL=https://YOUR_APP_DOMAIN:8443

# ── [공통] 관리자 계정 ───────────────────────────────────────
# Synology 로그인 ID를 쉼표로 구분하여 입력
ADMIN_USERS=sweatmoon

# ── [운영] Docker 이미지 태그 ────────────────────────────────
# latest (기본) 또는 특정 커밋 SHA (롤백용)
IMAGE_TAG=latest

# ── [운영] 백업 설정 ─────────────────────────────────────────
BACKUP_KEEP_DAYS=30

# ── [운영 선택] Watchtower 이메일 알림 ──────────────────────
# 컨테이너 재시작 시 이메일 알림 (비워두면 알림 없음)
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=

# ── [개발] 로그 수준 ─────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

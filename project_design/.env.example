# ============================================================
# .env.example  ─  환경 변수 템플릿
# ============================================================
# 1) cp .env.example .env
# 2) .env 파일을 편집해서 실제 값 입력
# 3) .env 는 절대 Git에 커밋하지 마세요! (.gitignore 에 등록됨)
# ============================================================

# ── [공통] 서버 기본 설정 ────────────────────────────────────
PORT=8080

# development | production
ENVIRONMENT=production

# ── [공통] PostgreSQL DB 설정 ────────────────────────────────
# docker-compose 가 자동으로 DATABASE_URL 을 조립합니다.
# 아래 비밀번호를 안전한 값으로 변경하세요 (필수!)
# 생성법: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change_me_please

# ── [공통] JWT 설정 ──────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열 (필수!)
# 생성법: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=8

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ── [운영] 시놀로지 NAS OIDC 설정 ───────────────────────────
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# ⚠️  포트 & 역방향 프록시 구성 가이드 (Synology DSM 기준)
#
# [방법 A] DSM Application Portal 역방향 프록시 사용 (권장)
#   ① DSM > 제어판 > Application Portal > 역방향 프록시 > 만들기
#      - 원본:  HTTPS  activo-no1.synology.me  8443
#      - 대상:  HTTP   localhost               8080  ← 컨테이너 내부 포트
#      - "WebSocket 지원 활성화" 체크
#   ② .env:
#      APP_HOST_PORT=8080          ← 역방향 프록시가 컨테이너 8080에 직접 접근
#      APP_URL=https://activo-no1.synology.me:8443
#      OIDC_REDIRECT_URI=https://activo-no1.synology.me:8443/auth/callback
#
# [방법 B] 역방향 프록시 없이 직접 포트 노출
#   ① DSM > 방화벽에서 외부 포트 8443 개방
#   ② .env:
#      APP_HOST_PORT=8443          ← 컨테이너 포트 8080을 호스트 8443으로 매핑
#      APP_URL=https://activo-no1.synology.me:8443
#      OIDC_REDIRECT_URI=https://activo-no1.synology.me:8443/auth/callback
#   ③ HTTPS는 NAS 자체 인증서(DSM > 보안 > 인증서)로 처리
#
# 현재 설정 (activo-no1.synology.me:8443 기준):
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 개발 환경에서는 비워두면 dev-login(자동 관리자) 활성화
# 운영 환경에서는 아래 4개 값을 반드시 입력
OIDC_ISSUER_URL=https://activo-no1.synology.me/webman/sso
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_REDIRECT_URI=https://activo-no1.synology.me:8443/auth/callback
APP_URL=https://activo-no1.synology.me:8443

# 컨테이너 호스트 포트 (docker-compose.prod.yml 에서 사용)
# 방법 A(역방향 프록시): 8080
# 방법 B(직접 포트): 8443
APP_HOST_PORT=8080

# ── [공통] 관리자 계정 ───────────────────────────────────────
# Synology 로그인 ID를 쉼표로 구분하여 입력
ADMIN_USERS=sweatmoon

# ── [운영] Docker 이미지 태그 ────────────────────────────────
# latest (기본) 또는 특정 커밋 SHA (롤백용)
IMAGE_TAG=latest

# ── [운영] 백업 설정 ─────────────────────────────────────────
BACKUP_KEEP_DAYS=30

# ── [운영 선택] Watchtower 이메일 알림 ──────────────────────
# 컨테이너 재시작 시 이메일 알림 (비워두면 알림 없음)
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=

# ── [개발] 로그 수준 ─────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

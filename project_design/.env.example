# ====================================================
# 프로젝트 일정 관리 시스템 - 환경 변수 설정
# ====================================================
# 이 파일을 복사하여 .env 로 만든 후 실제 값을 입력하세요.
# cp .env.example .env

# ── 서버 기본 설정 ──────────────────────────────────
PORT=8080
ENVIRONMENT=production
DATABASE_URL=sqlite:////data/app.db

# ── JWT 설정 ─────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열로 변경 (필수!)
# 생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=8

# ── 시놀로지 NAS OIDC 설정 ──────────────────────────
# 설정 안 하면 인증 없이 동작 (내부망 전용 시 가능)
# 설정하면 시놀로지 NAS 계정으로 로그인 필요

# 시놀로지 NAS SSO 서버 URL (DSM > 응용 프로그램 포털 > SSO 서버에서 확인)
# 예시: https://192.168.1.100:5001/webman/sso
# 예시: https://yournas.synology.me/webman/sso
OIDC_ISSUER_URL=https://YOUR_NAS_IP_OR_DOMAIN:5001/webman/sso

# 시놀로지 SSO에서 등록한 애플리케이션 ID (클라이언트 ID)
OIDC_CLIENT_ID=your_application_id

# 시놀로지 SSO에서 생성된 클라이언트 시크릿
OIDC_CLIENT_SECRET=your_client_secret

# 인증 후 돌아올 URL (이 앱의 주소 + /auth/callback)
# 예시: http://192.168.1.200:8080/auth/callback
# 예시: https://schedule.company.com/auth/callback
OIDC_REDIRECT_URI=http://YOUR_APP_HOST:8080/auth/callback

# 이 앱의 외부 접근 URL (로그인 후 리다이렉트에 사용)
APP_URL=http://YOUR_APP_HOST:8080

# ── 선택적 설정 ──────────────────────────────────────
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
